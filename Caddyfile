# Sustituye tu-dominio.ddns.net por el dominio que hayas registrado en No-IP
# Caddy obtiene y renueva el certificado Let's Encrypt automáticamente

tu-dominio.ddns.net {

    # API REST → NestJS backend
    handle /api/* {
        reverse_proxy backend:3000
    }

    # Swagger UI (solo en desarrollo; quita en producción real)
    handle /swagger* {
        reverse_proxy backend:3000
    }

    # Todo lo demás → Angular frontend
    handle {
        reverse_proxy frontend:80
    }

    # Cabeceras de seguridad básicas
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Logs
    log {
        output file /var/log/caddy/access.log
        format json
    }
}
