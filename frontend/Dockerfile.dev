# ── Desarrollo: ng serve con hot reload ──────────────────────────────────────
FROM node:20-alpine AS development

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

EXPOSE 4200

# --host 0.0.0.0 es obligatorio para que Docker exponga el puerto al exterior
CMD ["npm", "run", "start", "--", "--host", "0.0.0.0", "--poll", "2000"]
